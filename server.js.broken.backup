294: function sanitizeProgress(value) {
295:   const base = defaultProgress();
296:   if (!value || typeof value !== 'object') return base;
297:   const questSeed = clamp(Math.floor(Number(value.questSeed) || 1), 1, 1_000_000);
298:   const quest = sanitizeQuest(value.quest, questSeed);
299:   return {
300:     coins: clamp(Math.floor(Number(value.coins) || 0), 0, 100_000_000),
301:     pickaxe: sanitizePickaxe(value.pickaxe, 'wood'),
302:     inventory: sanitizeInventory(value.inventory),
303:     questSeed,
304:     quest
305:   };
306: }
