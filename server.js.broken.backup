390: function readProfiles() {
391:   try {
392:     if (!fs.existsSync(PROFILE_FILE)) {
393:       return;
394:     }
395:     const fileData = fs.readFileSync(PROFILE_FILE, 'utf8');
396:     const parsed = JSON.parse(fileData);
397:     for (const [profileId, profile] of Object.entries(parsed)) {
398:       if (!sanitizeProfileId(profileId)) continue;
399:       const name = sanitizeName(profile?.name, `Player-${profileId.slice(0, 4)}`);
400:       const color = sanitizeColor(profile?.color, randomHexColor());
401:       const appearance = sanitizeAppearance(profile?.appearance, {
402:         ...defaultAppearance(),
403:         shirt: color
404:       });
405:       const x = Number(profile?.x);
406:       const y = Number(profile?.y);
407:       const z = Number(profile?.z);
408:       profiles.set(profileId, {
409:         name,
410:         color: appearance.shirt,
411:         appearance,
412:         x: Number.isFinite(x) ? x : null,
413:         y: Number.isFinite(y) ? y : null,
414:         z: Number.isFinite(z) ? z : null,
415:         progress: sanitizeProgress(profile?.progress)
416:       });
417:     }
418:   } catch {
419:     // Ignore corrupt profile storage and continue with runtime defaults.
420:   }
421: }
422: 
423: function readAccounts() {
424:   try {
425:     if (!fs.existsSync(ACCOUNT_FILE)) {
426:       return;
427:     }
428:     const fileData = fs.readFileSync(ACCOUNT_FILE, 'utf8');
429:     const parsed = JSON.parse(fileData);
430:     for (const [usernameKey, account] of Object.entries(parsed)) {
431:       const username = sanitizeUsername(usernameKey);
432:       if (!username) continue;
433:       const salt = typeof account?.salt === 'string' ? account.salt : '';
434:       const hash = typeof account?.hash === 'string' ? account.hash : '';
435:       const profileId = sanitizeProfileId(account?.profileId) || `acct-${username}`;
436:       if (!salt || !hash) continue;
437:       accounts.set(username, { username, salt, hash, profileId });
438:     }
439:   } catch {
440:     // Ignore corrupt account storage and continue.
441:   }
442: }
