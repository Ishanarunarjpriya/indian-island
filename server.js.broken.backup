502: function spawnPlayer(socket, profileId, username) {
503:   ensureProfileExists(profileId, username);
504:   const profile = profiles.get(profileId);
505:   const spawnPoint = randomSpawn(WORLD_LIMIT * 0.65);
506:   const savedX = Number(profile?.x);
507:   const savedY = Number(profile?.y);
508:   const savedZ = Number(profile?.z);
509:   const hasSavedPosition = Number.isFinite(savedX) && Number.isFinite(savedY) && Number.isFinite(savedZ);
510:   const savedInMine = hasSavedPosition
511:     && Math.hypot(savedX - MINE_POS.x, savedZ - MINE_POS.z) <= MINE_PLAY_RADIUS;
512:   const boundedSaved = hasSavedPosition
513:     ? clampToPlayableGround(
514:       clamp(savedX, -PLAYABLE_BOUND, PLAYABLE_BOUND),
515:       clamp(savedZ, -PLAYABLE_BOUND, PLAYABLE_BOUND),
516:       savedInMine
517:     )
518:     : null;
519:   const spawn = {
520:     id: socket.id,
521:     profileId,
522:     name: profile?.name || username || `Player-${socket.id.slice(0, 4)}`,
523:     x: boundedSaved ? boundedSaved.x : spawnPoint.x,
524:     y: hasSavedPosition ? clamp(savedY, SWIM_MIN_Y, 30) : ISLAND_SURFACE_Y,
525:     z: boundedSaved ? boundedSaved.z : spawnPoint.z,
526:     inMine: Boolean(savedInMine),
527:     appearance: sanitizeAppearance(profile?.appearance, {
528:       ...defaultAppearance(),
529:       shirt: profile?.color || randomHexColor()
530:     }),
531:     progress: sanitizeProgress(profile?.progress)
532:   };
533:   spawn.color = spawn.appearance.shirt;
534:   players.set(socket.id, spawn);
535:   socket.emit('init', {
536:     id: socket.id,
537:     players: [...players.values()],
538:     worldLimit: WORLD_LIMIT,
539:     interactables: [...interactables.values()],
540:     progress: progressSnapshot(spawn.progress)
541:   });
542:   socket.broadcast.emit('playerJoined', spawn);
543: }
