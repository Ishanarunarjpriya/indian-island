743:     const requestedIdx = PICKAXE_ORDER.indexOf(requested);
744:     if (requestedIdx !== currentIdx + 1) {
745:       if (typeof ack === 'function') ack({ ok: false, error: 'Buy pickaxes in order.' });
746:       return;
747:     }
