671:   socket.on('quest:claim', (payload, ack) => {
672:     const actor = players.get(socket.id);
673:     const progress = actor?.progress;
674:     const quest = progress?.quest;
675:     if (!actor || !progress || !quest || quest.status !== 'ready') {
676:       if (typeof ack === 'function') ack({ ok: false, error: 'No completed quest to claim.' });
677:       return;
678:     }
679:     progress.coins += quest.rewardCoins;
680:     if (quest.rewardDiamonds > 0) {
681:       progress.inventory.diamond += quest.rewardDiamonds;
682:     }
683:     const title = quest.title;
684:     const coins = quest.rewardCoins;
685:     const bonus = quest.rewardDiamonds;
686:     nextQuest(progress);
687:     persistPlayerProgress(actor);
688:     emitProgress(socket, actor);
689:     io.emit('chat', {
690:       fromName: 'System',
691:       text: `${actor.name} completed "${title}" for ${coins} coins${bonus ? ` and ${bonus} diamond` : ''}.`,
692:       sentAt: Date.now()
693:     });
694:     if (typeof ack === 'function') ack({ ok: true });
695:   });
696: 
697:   socket.on('mine:collect', (payload, ack) => {
698:     const actor = players.get(socket.id);
699:     const progress = actor?.progress;
700:     if (!actor || !progress) {
701:       if (typeof ack === 'function') ack({ ok: false });
702:       return;
703:     }
704:     const nearMine = Math.hypot(actor.x - MINE_POS.x, actor.z - MINE_POS.z) <= MINE_RADIUS + 4.5;
705:     if (!nearMine) {
706:       if (typeof ack === 'function') ack({ ok: false, error: 'Go to the mine to collect ore.' });
707:       return;
708:     }
709:     const resource = ORE_TYPES.has(payload?.resource) ? payload.resource : null;
710:     const amount = clamp(Math.floor(Number(payload?.amount) || 0), 1, 20);
711:     if (!resource) {
712:       if (typeof ack === 'function') ack({ ok: false, error: 'Invalid ore type.' });
713:       return;
714:     }
715:     progress.inventory[resource] = clamp((progress.inventory[resource] || 0) + amount, 0, 1_000_000);
716:     const quest = progress.quest;
717:     let questProgressed = false;
718:     if (quest?.status === 'active' && quest.type === 'mine') {
719:       quest.progress = clamp(quest.progress + amount, 0, quest.targetCount);
720:       questProgressed = true;
721:       if (quest.progress >= quest.targetCount) {
722:         quest.status = 'ready';
723:       }
724:     }
725:     persistPlayerProgress(actor);
726:     emitProgress(socket, actor);
727:     if (typeof ack === 'function') ack({ ok: true, progress: progressSnapshot(progress), questProgressed });
728:   });
