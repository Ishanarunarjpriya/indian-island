327: function sanitizeAppearance(input, fallback) {
328:   const base = fallback || defaultAppearance();
329:   const payload = input && typeof input === 'object' ? input : {};
330: 
331:   return {
332:     skin: sanitizeColor(payload.skin, base.skin),
333:     shirt: sanitizeColor(payload.shirt ?? payload.color, base.shirt),
334:     pants: sanitizeColor(payload.pants, base.pants),
335:     shoes: sanitizeColor(payload.shoes, base.shoes),
336:     hairStyle: HAIR_STYLES.has(payload.hairStyle) ? payload.hairStyle : base.hairStyle,
337:     hairColor: sanitizeColor(payload.hairColor, base.hairColor),
338:     faceStyle: FACE_STYLES.has(payload.faceStyle) ? payload.faceStyle : base.faceStyle,
339:     accessories: Array.isArray(payload.accessories)
340:       ? [...new Set(payload.accessories.filter((item) => ACCESSORY_TYPES.has(item)))]
341:       : Array.isArray(base.accessories)
342:         ? [...new Set(base.accessories.filter((item) => ACCESSORY_TYPES.has(item)))]
343:         : []
344:   };
345: }
