650:   socket.on('quest:accept', (payload, ack) => {
651:     const actor = players.get(socket.id);
652:     if (!actor?.progress?.quest) {
653:       if (typeof ack === 'function') ack({ ok: false, error: 'Quest system unavailable.' });
654:       return;
655:     }
656:     const quest = actor.progress.quest;
657:     if (quest.status === 'ready') {
658:       if (typeof ack === 'function') ack({ ok: false, error: 'Claim your current quest reward first.' });
659:       return;
660:     }
661:     if (quest.status === 'active') {
662:       if (typeof ack === 'function') ack({ ok: true, quest, alreadyActive: true });
663:       return;
664:     }
665:     quest.status = 'active';
666:     persistPlayerProgress(actor);
667:     emitProgress(socket, actor);
668:     if (typeof ack === 'function') ack({ ok: true, quest });
669:   });
