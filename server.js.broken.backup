221: function defaultQuest(seed = 1) {
222:   const pool = [
223:     { resource: 'stone', min: 14, max: 28, rewardPerItem: 3, diamondBonusChance: 0.08 },
224:     { resource: 'iron', min: 8, max: 18, rewardPerItem: 7, diamondBonusChance: 0.12 },
225:     { resource: 'gold', min: 6, max: 14, rewardPerItem: 11, diamondBonusChance: 0.16 },
226:     { resource: 'diamond', min: 2, max: 7, rewardPerItem: 32, diamondBonusChance: 0.2 }
227:   ];
228:   const entry = pool[seed % pool.length];
229:   const span = entry.max - entry.min + 1;
230:   const targetCount = entry.min + ((seed * 7) % span);
231:   const rewardCoins = Math.round(targetCount * entry.rewardPerItem + 24 + Math.min(160, seed * 2.8));
232:   const rewardDiamonds = Math.random() < entry.diamondBonusChance ? 1 : 0;
233:   return {
234:     id: `q-${Date.now()}-${seed}`,
235:     type: 'mine',
236:     resource: entry.resource,
237:     targetCount,
238:     progress: 0,
239:     rewardCoins,
240:     rewardDiamonds,
241:     title: `Mine ${targetCount} ore`,
242:     description: `Collect ${targetCount} ore chunks in the mine.`,
243:     status: 'available'
244:   };
245: }
246: 
