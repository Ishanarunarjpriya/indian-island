564: function removeAuthenticatedPlayer(socket) {
565:   const existing = players.get(socket.id);
566:   if (!existing) return;
567:   persistPlayerProgress(existing);
568:   players.delete(socket.id);
569:   voiceParticipants.delete(socket.id);
570:   socket.broadcast.emit('voice:user-left', socket.id);
571:   io.emit('playerLeft', socket.id);
572: }
