271: function sanitizeQuest(value, fallbackSeed = 1) {
272:   const fallback = defaultQuest(fallbackSeed);
273:   if (!value || typeof value !== 'object') return fallback;
274:   const resource = ORE_TYPES.has(value.resource) ? value.resource : fallback.resource;
275:   const targetCount = clamp(Math.floor(Number(value.targetCount) || fallback.targetCount), 1, 2000);
276:   const progress = clamp(Math.floor(Number(value.progress) || 0), 0, targetCount);
277:   const rewardCoins = clamp(Math.floor(Number(value.rewardCoins) || fallback.rewardCoins), 5, 50_000);
278:   const rewardDiamonds = clamp(Math.floor(Number(value.rewardDiamonds) || 0), 0, 50);
279:   const status = ['available', 'active', 'ready'].includes(value.status) ? value.status : fallback.status;
280:   return {
281:     id: typeof value.id === 'string' && value.id ? value.id.slice(0, 80) : fallback.id,
282:     type: 'mine',
283:     resource,
284:     targetCount,
285:     progress,
286:     rewardCoins,
287:     rewardDiamonds,
288:     title: `Mine ${targetCount} ore`,
289:     description: `Collect ${targetCount} ore chunks in the mine.`,
290:     status: progress >= targetCount && status === 'active' ? 'ready' : status
291:   };
292: }
