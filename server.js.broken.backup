261: function sanitizeInventory(value) {
262:   const base = defaultInventory();
263:   if (!value || typeof value !== 'object') return base;
264:   for (const key of Object.keys(base)) {
265:     const n = Number(value[key]);
266:     base[key] = Number.isFinite(n) ? clamp(Math.floor(n), 0, 1_000_000) : 0;
267:   }
268:   return base;
269: }
