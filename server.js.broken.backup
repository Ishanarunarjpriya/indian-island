444: function scheduleProfileSave() {
445:   if (saveTimer) {
446:     clearTimeout(saveTimer);
447:   }
448:   saveTimer = setTimeout(() => {
449:     saveTimer = null;
450:     const serialized = {};
451:     for (const [profileId, profile] of profiles.entries()) {
452:       serialized[profileId] = {
453:         name: profile.name,
454:         color: profile.color,
455:         appearance: profile.appearance,
456:         x: Number.isFinite(profile.x) ? profile.x : null,
457:         y: Number.isFinite(profile.y) ? profile.y : null,
458:         z: Number.isFinite(profile.z) ? profile.z : null,
459:         progress: sanitizeProgress(profile.progress)
460:       };
461:     }
462:     fs.writeFile(PROFILE_FILE, JSON.stringify(serialized, null, 2), () => {});
463:   }, 250);
464: }
