545: function persistPlayerProgress(player) {
546:   if (!player?.profileId) return;
547:   profiles.set(player.profileId, {
548:     name: player.name,
549:     color: player.color,
550:     appearance: player.appearance,
551:     x: player.x,
552:     y: player.y,
553:     z: player.z,
554:     progress: sanitizeProgress(player.progress)
555:   });
556:   scheduleProfileSave();
557: }
558: 
559: function emitProgress(socket, player) {
560:   if (!socket || !player?.progress) return;
561:   socket.emit('progress:update', progressSnapshot(player.progress));
562: }
