374: function hashPassword(password, salt = crypto.randomBytes(16).toString('hex')) {
375:   const hash = crypto.scryptSync(password, salt, 64).toString('hex');
376:   return { salt, hash };
377: }
378: 
379: function verifyPassword(password, salt, expectedHash) {
380:   try {
381:     const computed = crypto.scryptSync(password, salt, 64).toString('hex');
382:     const a = Buffer.from(computed, 'hex');
383:     const b = Buffer.from(expectedHash, 'hex');
384:     return a.length === b.length && crypto.timingSafeEqual(a, b);
385:   } catch {
386:     return false;
387:   }
388: }
