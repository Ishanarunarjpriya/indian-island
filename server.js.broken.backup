94: function clampToIsland(x, z, limit) {
95:   const radius = Math.hypot(x, z);
96:   if (radius <= limit) {
97:     return { x, z };
98:   }
99: 
100:   const scale = limit / (radius || 1);
101:   return { x: x * scale, z: z * scale };
102: }
103: 
104: function clampToPlayableGround(x, z, allowMine = false) {
105:   const MAIN_RADIUS = WORLD_LIMIT * 1.14;
106:   const MINE_ENTRY_RADIUS = MINE_ENTRY_ISLAND_RADIUS;
107:   const mineDist = Math.hypot(x - MINE_POS.x, z - MINE_POS.z);
108:   const mineSwimBlocked = allowMine && mineDist <= MINE_SWIM_BLOCK_RADIUS;
109:   const onMain = Math.hypot(x, z) <= MAIN_RADIUS;
110:   const onLighthouse = Math.hypot(x - LIGHTHOUSE_POS.x, z - LIGHTHOUSE_POS.z) <= LIGHTHOUSE_RADIUS;
111:   const onMineEntryIsland = Math.hypot(x - MINE_ENTRY_ISLAND_POS.x, z - MINE_ENTRY_ISLAND_POS.z) <= MINE_ENTRY_RADIUS;
112:   const onInterior = Math.hypot(x - INTERIOR_POS.x, z - INTERIOR_POS.z) <= INTERIOR_RADIUS;
113:   const onMine = allowMine && mineDist <= MINE_PLAY_RADIUS;
114:   const radius = Math.hypot(x, z);
115:   const onSwimRing = radius >= SWIM_MIN_RADIUS && radius <= SWIM_MAX_RADIUS && !mineSwimBlocked;
116:   if (onMain || onLighthouse || onMineEntryIsland || onInterior || onMine || onSwimRing) {
117:     return { x, z };
118:   }
119: 
120:   const toMain = clampToIsland(x, z, MAIN_RADIUS);
121:   const distMain = Math.hypot(x - toMain.x, z - toMain.z);
122: 
123:   const dxL = x - LIGHTHOUSE_POS.x;
124:   const dzL = z - LIGHTHOUSE_POS.z;
125:   const lenL = Math.hypot(dxL, dzL) || 1;
126:   const toLighthouse = {
127:     x: LIGHTHOUSE_POS.x + (dxL / lenL) * LIGHTHOUSE_RADIUS,
128:     z: LIGHTHOUSE_POS.z + (dzL / lenL) * LIGHTHOUSE_RADIUS
129:   };
130:   const distLighthouse = Math.hypot(x - toLighthouse.x, z - toLighthouse.z);
131:   const dxE = x - MINE_ENTRY_ISLAND_POS.x;
132:   const dzE = z - MINE_ENTRY_ISLAND_POS.z;
133:   const lenE = Math.hypot(dxE, dzE) || 1;
134:   const toMineEntry = {
135:     x: MINE_ENTRY_ISLAND_POS.x + (dxE / lenE) * MINE_ENTRY_RADIUS,
136:     z: MINE_ENTRY_ISLAND_POS.z + (dzE / lenE) * MINE_ENTRY_RADIUS
137:   };
138:   const distMineEntry = Math.hypot(x - toMineEntry.x, z - toMineEntry.z);
139: 
140:   const dxI = x - INTERIOR_POS.x;
141:   const dzI = z - INTERIOR_POS.z;
142:   const lenI = Math.hypot(dxI, dzI) || 1;
143:   const toInterior = {
144:     x: INTERIOR_POS.x + (dxI / lenI) * INTERIOR_RADIUS,
145:     z: INTERIOR_POS.z + (dzI / lenI) * INTERIOR_RADIUS
146:   };
147:   const distInterior = Math.hypot(x - toInterior.x, z - toInterior.z);
148:   const dxM = x - MINE_POS.x;
149:   const dzM = z - MINE_POS.z;
150:   const lenM = Math.hypot(dxM, dzM) || 1;
151:   const toMine = {
152:     x: MINE_POS.x + (dxM / lenM) * MINE_PLAY_RADIUS,
153:     z: MINE_POS.z + (dzM / lenM) * MINE_PLAY_RADIUS
154:   };
155:   const distMine = allowMine ? Math.hypot(x - toMine.x, z - toMine.z) : Number.POSITIVE_INFINITY;
156:   const toSwim = (() => {
157:     const len = Math.hypot(x, z) || 1;
158:     const target = len < SWIM_MIN_RADIUS ? SWIM_MIN_RADIUS : SWIM_MAX_RADIUS;
159:     const scale = target / len;
160:     return { x: x * scale, z: z * scale };
161:   })();
162:   const distSwim = mineSwimBlocked ? Number.POSITIVE_INFINITY : Math.hypot(x - toSwim.x, z - toSwim.z);
163: 
164:   if (distMain <= distLighthouse && distMain <= distMineEntry && distMain <= distInterior && distMain <= distSwim && distMain <= distMine) return toMain;
165:   if (distLighthouse <= distMineEntry && distLighthouse <= distInterior && distLighthouse <= distSwim && distLighthouse <= distMine) return toLighthouse;
166:   if (distMineEntry <= distInterior && distMineEntry <= distSwim && distMineEntry <= distMine) return toMineEntry;
167:   if (distInterior <= distSwim && distInterior <= distMine) return toInterior;
168:   if (distMine <= distSwim) return toMine;
169:   return toSwim;
170: }
