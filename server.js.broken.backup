186: function sanitizeName(value, fallback) {
187:   const raw = typeof value === 'string' ? value : '';
188:   const normalized = raw.replace(/\s+/g, ' ').trim().slice(0, NAME_MAX_LEN);
189:   const safe = normalized.replace(/[\x00-\x1F\x7F<>]/g, '');
190:   return safe || fallback;
191: }
