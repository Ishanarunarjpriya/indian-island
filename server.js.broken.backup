577:   socket.on('auth:register', (payload, ack) => {
578:     const username = sanitizeUsername(payload?.username);
579:     const password = sanitizePassword(payload?.password);
580:     if (!username || !password) {
581:       if (typeof ack === 'function') ack({ ok: false, error: 'Use 3-20 letters/numbers for username and min 4-char password.' });
582:       return;
583:     }
584:     if (accounts.has(username)) {
585:       if (typeof ack === 'function') ack({ ok: false, error: 'Username already exists.' });
586:       return;
587:     }
588:     const { salt, hash } = hashPassword(password);
589:     const profileId = `acct-${username}`;
590:     accounts.set(username, { username, salt, hash, profileId });
591:     scheduleAccountSave();
592:     ensureProfileExists(profileId, username);
593:     spawnPlayer(socket, profileId, username);
594:     if (typeof ack === 'function') ack({ ok: true, username });
595:   });
596: 
597:   socket.on('auth:login', (payload, ack) => {
598:     const username = sanitizeUsername(payload?.username);
599:     const password = sanitizePassword(payload?.password);
600:     if (!username || !password) {
601:       if (typeof ack === 'function') ack({ ok: false, error: 'Invalid username or password.' });
602:       return;
603:     }
604:     const account = accounts.get(username);
605:     if (!account || !verifyPassword(password, account.salt, account.hash)) {
606:       if (typeof ack === 'function') ack({ ok: false, error: 'Invalid username or password.' });
607:       return;
608:     }
609:     ensureProfileExists(account.profileId, username);
610:     spawnPlayer(socket, account.profileId, username);
611:     if (typeof ack === 'function') ack({ ok: true, username });
612:   });
613: 
614:   socket.on('auth:logout', () => {
