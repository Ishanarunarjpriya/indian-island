172: function randomSpawn(limit) {
173:   const angle = Math.random() * Math.PI * 2;
174:   const radius = Math.sqrt(Math.random()) * limit;
175:   return {
176:     x: Math.cos(angle) * radius,
177:     z: Math.sin(angle) * radius
178:   };
179: }
