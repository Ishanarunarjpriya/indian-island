618:   socket.on('move', (payload) => {
619:     const current = players.get(socket.id);
620:     if (!current || !payload) return;
621: 
622:     const x = Number(payload.x);
623:     const y = Number(payload.y);
624:     const z = Number(payload.z);
625:     const nextX = Number.isFinite(x) ? x : current.x;
626:     const nextY = Number.isFinite(y) ? y : current.y;
627:     const nextZ = Number.isFinite(z) ? z : current.z;
628:     const boundedX = clamp(nextX, -PLAYABLE_BOUND, PLAYABLE_BOUND);
629:     const boundedZ = clamp(nextZ, -PLAYABLE_BOUND, PLAYABLE_BOUND);
630:     const inMine = payload?.inMine === true;
631:     const next = clampToPlayableGround(boundedX, boundedZ, inMine);
632: 
633:     current.x = next.x;
634:     current.y = clamp(nextY, SWIM_MIN_Y, 30);
635:     current.z = next.z;
636:     players.set(socket.id, current);
637:     persistPlayerProgress(current);
638: 
639:     socket.broadcast.emit('playerMoved', {
640:       id: socket.id,
641:       x: current.x,
642:       y: current.y,
643:       z: current.z,
644:       name: current.name,
645:       color: current.color,
646:       appearance: current.appearance
647:     });
648:   });
