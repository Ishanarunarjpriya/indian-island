487: function ensureProfileExists(profileId, username) {
488:   if (!profileId || profiles.has(profileId)) return;
489:   const shirt = randomHexColor();
490:   profiles.set(profileId, {
491:     name: sanitizeName(username, username || `Player-${profileId.slice(0, 4)}`),
492:     color: shirt,
493:     appearance: sanitizeAppearance(null, { ...defaultAppearance(), shirt }),
494:     x: null,
495:     y: null,
496:     z: null,
497:     progress: defaultProgress()
498:   });
499:   scheduleProfileSave();
500: }
